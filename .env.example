# Server Configuration
PORT=4000

# OpenRouter (Optional - falls back to Ollama if not set)
# OPENROUTER_API_KEY=your_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Application Metadata (for OpenRouter)
APP_URL=http://localhost:4000
APP_NAME=Copilot App

# Ollama Configuration
OLLAMA_API=http://localhost:11434

# Speech-to-Text Service
STT_API=http://localhost:8001/transcribe

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/copilot
USE_DATABASE=true

# File-based Storage (Fallback)
MEETINGS_DIR=data/meetings

# Windows Automation
AUTOMATION_MODE=dry-run
# For live automation, set to: AUTOMATION_MODE=live
# And set optional endpoint:
# AUTOMATION_ENDPOINT=http://host.docker.internal:4010

# Hugging Face Token (for STT models)
# HF_TOKEN=your_hf_token_here
